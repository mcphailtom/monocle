{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": [
    "go@1.23",
    "lefthook@latest",
    "bun@latest",
    "wails@latest"
  ],
  "shell": {
    "init_hook": [
      "lefthook install",
      "export MONOCLE_DB=$PWD/.monocle-dev.db",
      "export PATH=$PWD/bin:$PATH"
    ]
  }
}
