{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "./bin/monocle hooks exit-plan --agent claude",
            "timeout": 345600,
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "./bin/monocle hooks mark-activity --agent claude",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|NotebookEdit|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "./bin/monocle hooks enter-plan --agent claude",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "echo 'export PATH=\"./bin:$PATH\"' \u003e\u003e \"$CLAUDE_ENV_FILE\"",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "./bin/monocle hooks on-stop --agent claude",
            "timeout": 345600,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(uname:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(devbox run -- make*)",
      "Bash(monocle review:*)",
      "Bash(./bin/monocle review:*)"
    ]
  }
}
